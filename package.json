{
  "name": "react-example",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --port=3000 --host=0.0.0.0",
    "backend:dev": "tsx backend/src/server.ts",
    "backend:build": "tsc --project backend/tsconfig.json",
    "backend:start": "node backend/dist/server.js",
    "backend:typecheck": "tsc --project backend/tsconfig.json --noEmit",
    "prisma:generate": "prisma generate --schema backend/prisma/schema.prisma",
    "prisma:validate": "prisma validate --schema backend/prisma/schema.prisma",
    "prisma:db:push": "prisma db push --schema backend/prisma/schema.prisma",
    "prisma:migrate:dev": "prisma migrate dev --schema backend/prisma/schema.prisma",
    "prisma:seed": "tsx backend/prisma/seed.ts",
    "build": "vite build",
    "preview": "vite preview",
    "clean": "rm -rf dist",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@google/genai": "^1.29.0",
    "@prisma/client": "^6.7.0",
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "resend": "^6.12.0",
    "vite": "^6.2.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "autoprefixer": "^10.4.21",
    "prisma": "^6.7.0",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.0"
  }
}
